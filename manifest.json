{
  "manifest_version": 3,
  "name": "Passive Aggressive Translator",
  "description": "Decode corporate speak and passive-aggressive language to reveal what people actually mean",
  "version": "1.0.0",
  "permissions": ["activeTab","storage","contextMenus","tabs"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "32": "icons/icons32.png" }
  },
  "icons": { "32": "icons/icons32.png" },
  "background": { "service_worker": "background.js" },
  "content_scripts": [{ "matches": ["<all_urls>"], "js": ["content.js"], "css": ["content.css"] }],
  "host_permissions": ["https://generativelanguage.googleapis.com/*","https://openrouter.ai/*"]
}
